      "name": "Alerta a Telegram / Mail",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1850, 100],
      "notesInFlow": true,
      "notes": "Avisar a Axel que no completó la calcu"
    }
  ],
  "connections": {
